# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Windows reserved names
nul

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code worktrees (transient working copies; should never be tracked)
.claude/worktrees/

# codex agent scratch artifacts (browser profiles, screenshots, dev-server logs)
.codex-*
